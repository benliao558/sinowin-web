# Resend (https://resend.com) API key, used by src/app/api/contact/route.ts
# to send the homepage contact form submissions to info@sinowin-vn.com.
# Get one from https://resend.com/api-keys and set it in Vercel project
# environment variables (Settings -> Environment Variables), not committed here.
RESEND_API_KEY=

# Sanity CMS (https://sanity.io) -- powers the /studio content editor.
# Project ID and dataset are not secret (they're public, needed client-side
# to load the Studio); the API token IS secret and only needed once we wire
# up server-side reads/writes in a later phase.
NEXT_PUBLIC_SANITY_PROJECT_ID=rvwbzxhf
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# LinkedIn auto-publish (src/app/api/linkedin/*, src/lib/linkedin/*).
# Client ID/Secret come from the LinkedIn Developer Portal app (redirect URL
# registered there must be https://www.sinowin-vn.com/api/linkedin/callback).
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# 32-byte key (base64) used to encrypt LinkedIn access/refresh tokens before
# they're stored in Sanity -- required because the "production" dataset
# above has public read access. Generate with: openssl rand -base64 32
LINKEDIN_TOKEN_ENCRYPTION_KEY=

# Shared secret gating the internal /linkedin-admin page and the
# authorize/status API routes (?key=... query param). Pick any long random string.
LINKEDIN_ADMIN_SECRET=

# Configured as the webhook's "Secret" when creating the Sanity webhook
# (sanity.io/manage -> project -> API -> Webhooks) that calls /api/linkedin/sync.
SANITY_WEBHOOK_SECRET=

# Vercel sets this automatically for Vercel Cron-triggered requests once you
# add CRON_SECRET as an env var yourself; protects /api/linkedin/refresh.
CRON_SECRET=
