# Resend (https://resend.com) API key, used by src/app/api/contact/route.ts
# to send the homepage contact form submissions to info@sinowin-vn.com.
# Get one from https://resend.com/api-keys and set it in Vercel project
# environment variables (Settings -> Environment Variables), not committed here.
RESEND_API_KEY=

# Sanity CMS (https://sanity.io) -- powers the /studio content editor.
# Project ID and dataset are not secret (they're public, needed client-side
# to load the Studio); the API token IS secret and only needed once we wire
# up server-side reads/writes in a later phase.
NEXT_PUBLIC_SANITY_PROJECT_ID=rvwbzxhf
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=
